# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/devops_dashboard

# GitHub Actions API (used to trigger workflow_dispatch on your MERN repos)
# Create a fine-grained PAT with "Actions: Read and write" permission
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Health check scheduler (cron expression, default every 5 minutes)
HEALTH_CHECK_CRON=*/5 * * * *

# Alerting - Discord webhook (recommended, simplest to demo)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/xxxx

# Alerting - Email via Nodemailer (optional, alternative to Discord)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL_TO=you@example.com

# How many consecutive failures before an alert fires (avoids noisy flapping alerts)
ALERT_FAILURE_THRESHOLD=1
